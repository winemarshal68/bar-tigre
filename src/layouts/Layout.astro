---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang: 'es' | 'en' | 'fr';
  page: 'home' | 'menu' | 'contact';
  leafletMap?: boolean;
}

const { title, description, lang, page, leafletMap = false } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#1a0a06" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/images/logo.svg" />
  {leafletMap && (
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  )}
</head>
<body class="min-h-screen flex flex-col">
  <Header lang={lang} page={page} />
  <main class="flex-1">
    <slot />
  </main>
  <Footer lang={lang} />

  {leafletMap && (
    <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV/XN/sp38=" crossorigin=""></script>
  )}
</body>
</html>
