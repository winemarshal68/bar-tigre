---
interface Props {
  title: string;
  body: string;
  ctaMenu: string;
  ctaMenuHref: string;
  ctaLocation: string;
  ctaLocationHref: string;
}

const {
  title, body,
  ctaMenu, ctaMenuHref,
  ctaLocation, ctaLocationHref,
} = Astro.props;

// Split title on \n for the serif line break
const titleLines = title.split('\n');
---

<section class="hero-bg min-h-[88vh] flex flex-col justify-center">
  <div class="max-w-3xl mx-auto px-6 py-24 text-center">

    <!-- Main title -->
    <h1 class="font-serif text-cream text-4xl sm:text-5xl md:text-6xl leading-tight mb-6 drop-shadow-lg">
      {titleLines.map((line, i) => (
        <>
          {i > 0 && <br />}
          {line}
        </>
      ))}
    </h1>

    <!-- Subheadline -->
    <p class="text-cream/80 text-lg sm:text-xl max-w-xl mx-auto mb-10 leading-relaxed">
      {body}
    </p>

    <!-- CTAs -->
    <div class="flex flex-wrap justify-center gap-10 mt-2">
      <a href={ctaMenuHref}
         class="text-gold tracking-widest uppercase text-sm font-semibold
                border-b border-transparent hover:border-gold/60
                transition-colors duration-200 pb-px">
        {ctaMenu} &rarr;
      </a>
      <a href={ctaLocationHref}
         class="text-cream/70 tracking-widest uppercase text-sm font-semibold
                border-b border-transparent hover:border-cream/40
                transition-colors duration-200 pb-px">
        {ctaLocation} &rarr;
      </a>
    </div>

  </div>
</section>
