---
import esT from '../i18n/es.json';
import enT from '../i18n/en.json';
import frT from '../i18n/fr.json';

interface Props {
  lang: 'es' | 'en' | 'fr';
}

const { lang } = Astro.props;
const t = lang === 'es' ? esT : lang === 'en' ? enT : frT;
const year = new Date().getFullYear();

const phone = t.contact.phone;
const phoneHref = t.contact.phone_href;
---

<footer class="bg-espresso text-cream/70 border-t border-mahogany/60">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">

      <!-- Brand -->
      <div class="flex flex-col items-start gap-3">
        <img src="/images/logo-white.svg"
             alt="Restaurante Bar León"
             width="56"
             height="56"
             loading="lazy"
             class="h-14 w-14 object-contain opacity-90" />
        <div>
          <p class="font-serif text-cream text-lg leading-tight">Restaurante Bar León</p>
          <p class="text-gold text-sm mt-0.5">{t.footer.tagline}</p>
        </div>
      </div>

      <!-- Address & Hours -->
      <div class="text-sm space-y-1">
        <p class="font-semibold text-cream/90 uppercase tracking-wider text-xs mb-2">
          {t.contact.address_label}
        </p>
        <p>{t.contact.address}</p>
        <p class="text-cream/50">{t.contact.near}</p>
        <p class="mt-3">
          <a href={phoneHref}
             class="text-gold hover:text-cream transition-colors duration-150 font-medium">
            {phone}
          </a>
        </p>
      </div>

      <!-- Quick nav -->
      <div class="text-sm space-y-2">
        <p class="font-semibold text-cream/90 uppercase tracking-wider text-xs mb-2">
          {lang === 'es' ? 'Secciones' : lang === 'en' ? 'Sections' : 'Sections'}
        </p>
        <ul class="space-y-1">
          <li>
            <a href={lang === 'es' ? '/' : `/${lang}/`}
               class="hover:text-gold transition-colors duration-150">
              {t.nav.home}
            </a>
          </li>
          <li>
            <a href={lang === 'es' ? '/menu' : `/${lang}/menu`}
               class="hover:text-gold transition-colors duration-150">
              {t.nav.menu}
            </a>
          </li>
          <li>
            <a href={lang === 'es' ? '/contacto' : `/${lang}/contact`}
               class="hover:text-gold transition-colors duration-150">
              {t.nav.contact}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-mahogany/60 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-2 text-xs text-cream/40">
      <p>© {year} Restaurante Bar León, Granada. {t.footer.rights}.</p>
      <p>
        <a href="https://www.openstreetmap.org/copyright"
           target="_blank"
           rel="noopener noreferrer"
           class="hover:text-gold transition-colors duration-150">
          Map © OpenStreetMap contributors
        </a>
      </p>
    </div>
  </div>
</footer>
