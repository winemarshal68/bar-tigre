---
interface Props {
  address: string;
  lang?: 'es' | 'en' | 'fr';
}

const { address, lang = 'es' } = Astro.props;

// Approximate coordinates for C/ Pan 1, Granada — just behind Plaza Nueva.
// TODO: verify exact location with the client.
const LAT = 37.17759;
const LNG = -3.59978;
const ZOOM = 17;

// OSM iframe: bbox = west, south, east, north
const d = 0.003;
const bbox = `${LNG - d},${LAT - d},${LNG + d},${LAT + d}`;
const iframeSrc = `https://www.openstreetmap.org/export/embed.html?bbox=${bbox}&layer=mapnik&marker=${LAT},${LNG}`;

// Action links
const osmUrl   = `https://www.openstreetmap.org/?mlat=${LAT}&mlon=${LNG}#map=${ZOOM}/${LAT}/${LNG}`;
const dirUrl   = `https://www.openstreetmap.org/directions?to=${LAT},${LNG}`;

const labels = {
  es: { open: 'Abrir en OpenStreetMap', dir: 'Cómo llegar' },
  en: { open: 'Open in OpenStreetMap',  dir: 'Get directions' },
  fr: { open: 'Ouvrir dans OpenStreetMap', dir: 'Itinéraire' },
};
const lbl = labels[lang];
---

<div class="space-y-3">

  <!-- OSM iframe -->
  <div class="border border-tile overflow-hidden">
    <iframe
      src={iframeSrc}
      width="100%"
      height="320"
      style="border:0;display:block;"
      loading="lazy"
      referrerpolicy="no-referrer"
      title={address}
      aria-label={address}
    ></iframe>
  </div>

  <!-- Attribution -->
  <p class="text-xs text-mahogany/40">
    <a href="https://www.openstreetmap.org/copyright"
       target="_blank" rel="noopener noreferrer"
       class="hover:text-oxblood transition-colors duration-150">
      © OpenStreetMap contributors
    </a>
  </p>

  <!-- Action links -->
  <div class="flex flex-wrap gap-3 pt-1">
    <a href={osmUrl}
       target="_blank" rel="noopener noreferrer"
       class="btn-outline-dark text-sm px-4 py-2">
      {lbl.open}
    </a>
    <a href={dirUrl}
       target="_blank" rel="noopener noreferrer"
       class="btn-primary text-sm px-4 py-2">
      {lbl.dir}
    </a>
  </div>

</div>
