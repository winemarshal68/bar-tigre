---
import LangSwitcher from './LangSwitcher.astro';
import esT from '../i18n/es.json';
import enT from '../i18n/en.json';
import frT from '../i18n/fr.json';

interface Props {
  lang: 'es' | 'en' | 'fr';
  page: 'home' | 'menu' | 'contact';
}

const { lang, page } = Astro.props;
const t = lang === 'es' ? esT : lang === 'en' ? enT : frT;

const navItems = [
  { key: 'home',    href: lang === 'es' ? '/'          : `/${lang}/`,            label: t.nav.home    },
  { key: 'menu',    href: lang === 'es' ? '/menu'       : `/${lang}/menu`,        label: t.nav.menu    },
  { key: 'contact', href: lang === 'es' ? '/contacto'   : `/${lang}/contact`,     label: t.nav.contact },
];
---

<header class="bg-espresso sticky top-0 z-50 border-b border-mahogany/60">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href={lang === 'es' ? '/' : `/${lang}/`}
         class="flex items-center gap-3 shrink-0"
         aria-label="Restaurante Bar León — inicio">
        <img src="/images/logo-white.svg"
             alt="Bar León"
             width="40"
             height="40"
             loading="eager"
             class="h-10 w-10 object-contain" />
        <span class="font-serif text-cream text-lg leading-tight hidden sm:block">
          Bar León
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-6" aria-label="Navegación principal">
        {navItems.map(item => (
          <a href={item.href}
             class={`text-sm font-medium tracking-wide transition-colors duration-150 ${
               page === item.key
                 ? 'text-gold border-b border-gold pb-0.5'
                 : 'text-cream/75 hover:text-gold'
             }`}>
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Right: lang switcher + mobile toggle -->
      <div class="flex items-center gap-4">
        <LangSwitcher lang={lang} page={page} />

        <!-- Mobile hamburger -->
        <button id="menu-toggle"
                class="md:hidden text-cream/75 hover:text-gold p-1 focus:outline-none focus:ring-2 focus:ring-gold rounded"
                aria-label="Abrir menú de navegación"
                aria-expanded="false"
                aria-controls="mobile-nav">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none"
               viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path id="icon-open"  stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            <path id="icon-close" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" class="hidden" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile nav (hidden by default) -->
    <nav id="mobile-nav"
         class="hidden md:hidden pb-3 border-t border-mahogany/60 pt-3"
         aria-label="Navegación móvil">
      {navItems.map(item => (
        <a href={item.href}
           class={`block py-2 text-sm font-medium tracking-wide transition-colors duration-150 ${
             page === item.key ? 'text-gold' : 'text-cream/75 hover:text-gold'
           }`}>
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    var btn = document.getElementById('menu-toggle');
    var nav = document.getElementById('mobile-nav');
    var iconOpen = document.getElementById('icon-open');
    var iconClose = document.getElementById('icon-close');
    if (!btn || !nav) return;
    btn.addEventListener('click', function () {
      var expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      nav.classList.toggle('hidden');
      iconOpen.classList.toggle('hidden');
      iconClose.classList.toggle('hidden');
    });
  })();
</script>
